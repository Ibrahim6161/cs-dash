{
  "scheduler": {
    "enabled": true,
    "intervalMinutes": 360,
    "runOnStartup": true
  },
  "refresh": {
    "headless": true,
    "slowMo": 0,
    "pricePage": 1,
    "priceLimit": 50,
    "includeSteam": true,
    "steamLimit": 500,
    "steamConcurrency": 2,
    "includeTimeseries": false
  },
  "analysis": {
    "strictness": 55
  },
  "paths": {
    "cases": "cases.json",
    "details": "case_details.json",
    "steamCases": "out/steam-cases.json",
    "steamSkins": "out/steam-skins.json",
    "timeseries": "case-timeseries.json",
    "steamMarketTimeseries": "out/steam-market-timeseries.json",
    "shotsDir": "shots",
    "snapshotsDir": "out"
  }
}
